# ── Database ────────────────────────────────────────────────────────────────
# Local dev (file in project root):
DATABASE_URL="file:./dev.db?connection_limit=1&socket_timeout=60"
# Production on Railway/Render (persistent volume mounted at /data):
# DATABASE_URL="file:/data/dev.db?connection_limit=1&socket_timeout=60"

# ── App ──────────────────────────────────────────────────────────────────────
# Change to your real domain in production (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret used to protect the /api/sync route — generate a random string
SYNC_SECRET="change-me"

# ── Job filtering ─────────────────────────────────────────────────────────────
SOFTWARE_ONLY="true"
SOFTWARE_JOB_KEYWORDS="software engineer,software developer,full stack,frontend,backend,web developer,mobile engineer,ios,android,unity,unreal,gameplay programmer,game programmer,engine programmer,graphics programmer,tools engineer,devops,site reliability,sre,platform engineer,application engineer,machine learning engineer,data engineer,embedded software,firmware,test engineer,build engineer,new grad,junior engineer,associate engineer,software internship,intern software"

# ── ATS source tokens ─────────────────────────────────────────────────────────
GREENHOUSE_COMPANY_TOKENS="openai,figma,stripe,airtable,notion,robinhood,coinbase,scaleai,datadog,discord,doordash,dropbox,instacart,pinterest,reddit,snap,twilio,uber,affirm,brex,asana,canva,plaid,segment,unity,epicgames,riotgames,roblox,zynga,niantic"
LEVER_COMPANY_TOKENS="netflix,discord,robinhood,plaid,brex,flexport,postman,calendly,coursera,gusto,hashicorp"
ASHBY_COMPANY_TOKENS="anthropic,openai,vercel,ramp,perplexity,runway,linear,warp,retool,clerk,modal,railway"
WORKABLE_COMPANY_TOKENS="jerry,ozonetel,workable"
RECRUITEE_COMPANY_TOKENS="mollie,source"

# ── External job feeds ────────────────────────────────────────────────────────
ENABLE_REMOTIVE="true"
ENABLE_ARBEITNOW="true"
ARBEITNOW_API_URL="https://www.arbeitnow.com/api/job-board-api"
ARBEITNOW_MAX_PAGES="6"
ENABLE_GAMES_WORKBOOK="true"
GAMES_WORKBOOK_API_URL="https://games-jobs-workbook.replit.app/api/job-listings"
ENABLE_USAJOBS="false"
USAJOBS_USER_AGENT_EMAIL=""
USAJOBS_API_KEY=""
USAJOBS_KEYWORDS="software engineer,developer,programmer,applications software"
USAJOBS_RESULTS_PER_PAGE="250"
